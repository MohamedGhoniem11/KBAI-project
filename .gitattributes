# Auto detect text files and perform LF normalization
* text=auto

# Python
*.py text diff=python
*.pyw text
*.pyx text
*.pxd text
*.pxi text
*.pyi text

# Markdown
*.md text
*.mdx text

# Config files
*.yml text
*.yaml text
*.json text
*.toml text
*.cfg text
*.ini text
*.conf text

# Shell
*.sh text eol=lf
*.bash text eol=lf
*.zsh text eol=lf

# Docker
Dockerfile text
Dockerfile.* text
*.dockerfile text

# SVG (text-based)
*.svg text

# Binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
*.tar.gz binary
*.pdf binary
*.docx binary
*.faiss binary
*.pkl binary

# Git LFS for large files
data/vectorstore.tar.gz filter=lfs diff=lfs merge=lfs -text